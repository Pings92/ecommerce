{# {% extends 'base.html.twig' %}

{% block title %}Paiement Annulé - Nook Inc.{% endblock %}

{% block body %}
<style>
    :root {
        --nook-orange: #ff9d76;
        --nook-dark-orange: #e8865d;
        --nook-beige: #f9f6e5;
        --nook-brown: #8d775f;
    }

    body {
        background-color: #fff5f0; /* Fond pêche très clair */
        font-family: 'Arial Rounded MT Bold', sans-serif;
    }

    .cancel-card {
        background-color: var(--nook-beige);
        border: 8px solid white;
        border-radius: 50px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
        padding: 40px;
        margin-top: 10%;
    }

    .icon-circle-cancel {
        width: 100px;
        height: 100px;
        background-color: var(--nook-orange);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 50px;
        margin: 0 auto 20px;
        box-shadow: 0 5px 0 var(--nook-dark-orange);
    }

    .btn-nook-secondary {
        background-color: #a0d2eb; /* Bleu ciel doux */
        color: white;
        border: none;
        border-radius: 30px;
        padding: 12px 30px;
        font-weight: bold;
        transition: transform 0.2s;
        box-shadow: 0 4px 0 #89b8d0;
        text-decoration: none;
        display: inline-block;
    }

    .btn-nook-secondary:hover {
        transform: scale(1.05);
        color: white;
        background-color: #89b8d0;
    }

    .alert-nook {
        background: #ffffff;
        border-left: 5px solid var(--nook-orange);
        border-radius: 10px;
        padding: 15px;
        color: var(--nook-brown);
        font-size: 0.9rem;
    }
</style>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="cancel-card">
                <div class="icon-circle-cancel">
                    <i class="bi bi-x-lg">!</i>
                </div>

                <h1 class="display-6 fw-bold mb-3" style="color: var(--nook-brown);">
                    Oh... Une petite erreur ?
                </h1>
                
                <p class="lead mb-4" style="color: #777;">
                    Le paiement a été annulé ou n'a pas pu aboutir. <br>
                    Pas de panique, aucune clochette n'a été prélevée !
                </p>

                <div class="alert-nook mb-4 text-start">
                    <strong>Note de Nook Inc :</strong> <br>
                    Cela peut arriver si vous avez fermé la fenêtre trop tôt ou si votre banque a pris peur devant tant de clochettes.
                </div>

                <hr class="my-4" style="border-top: 2px dashed #d1ccb0;">

                <div class="d-grid gap-3 d-sm-flex justify-content-sm-center">
                    <a href="#" class="btn-nook-secondary">
                        Réessayer plus tard
                    </a>
                    <a href="#" class="btn btn-link text-muted" style="text-decoration: none;">
                        Retourner au village
                    </a>
                </div>

                <p class="mt-4 small text-muted italic">
                    "Prenez votre temps, la boutique ne s'envolera pas !" — Tom Nook
                </p>
            </div>
        </div>
    </div>
</div>
{% endblock %} #}