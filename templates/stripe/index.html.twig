{% extends 'base.html.twig' %}

{% block title %}Paiement Réussi - Nook Inc.{% endblock %}

{% block body %}
<style>
    :root {
        --nook-green: #78cead;
        --nook-beige: #f9f6e5;
        --nook-brown: #8d775f;
    }

    body {
        background-color: #f0fdf4; /* Vert très clair */
        font-family: 'Arial Rounded MT Bold', sans-serif;
    }

    .success-card {
        background-color: var(--nook-beige);
        border: 8px solid white;
        border-radius: 50px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
        padding: 40px;
        margin-top: 10%;
    }

    .icon-circle {
        width: 100px;
        height: 100px;
        background-color: var(--nook-green);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 50px;
        margin: 0 auto 20px;
        box-shadow: 0 5px 0 #5eb594;
    }

    .btn-nook {
        background-color: var(--nook-green);
        color: white;
        border: none;
        border-radius: 30px;
        padding: 12px 30px;
        font-weight: bold;
        transition: transform 0.2s;
        box-shadow: 0 4px 0 #5eb594;
        text-decoration: none;
        display: inline-block;
    }

    .btn-nook:hover {
        transform: scale(1.05);
        color: white;
        background-color: #69bc9c;
    }

    .receipt-id {
        background: white;
        border-radius: 15px;
        padding: 10px;
        font-family: monospace;
        color: var(--nook-brown);
        border: 2px dashed #d1ccb0;
    }
</style>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="success-card">
                <div class="icon-circle">
                    <i class="bi bi-check-lg">✓</i>
                </div>

                <h1 class="display-6 fw-bold mb-3" style="color: var(--nook-brown);">
                    Merci beaucoup, oui oui !
                </h1>
                
                <p class="lead mb-4" style="color: #666;">
                    Votre paiement a été traité avec succès. <br>
                    Votre compte de clochettes est désormais à jour !
                </p>

                <div class="mb-4">
                    <small class="text-muted d-block mb-2">Date de la transaction:</small>
                    <span class="receipt-id">#NOOK-{{ "now"|date("Ymd-His") }}</span>
                </div>

                <hr class="my-4" style="border-top: 2px dashed #d1ccb0;">

                <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
                    {# <a href="{{ path('app_task') }}" class="btn-nook"> #}
                        Retour au bureau de gestion
                    </a>
                </div>

                <p class="mt-4 small text-muted italic">
                    "Une affaire rondement menée !" — Tom Nook
                </p>
            </div>
        </div>
    </div>
</div>
{% endblock %}