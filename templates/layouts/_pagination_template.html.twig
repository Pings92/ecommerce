{% if pageCount > 1 %}
  <nav aria-label="...">
    <ul class="pagination">
    {% if previous is defined %}
      <li class="page-item">
        <a href="{{ path(route, query|merge({(pageParameterName):previous })) }}" class="page-link">Précédent</a>
      </li>
    {% endif %}
    {% for page in pagesInRange %}
      {% if  page != current %}
        <li class="page-item active" aria-current="page">
          <a class="page-link" href="{{ path(route, query|merge({(pageParameterName):page})) }}">{{ page }}</a>
        </li>
      {% else %}
      <li class="page-item active" aria-current="page">
        <a style="background:green" class="page-link" href="{{ path(route, query|merge({(pageParameterName):page})) }}">{{ page }}</a>
      </li>
      {% endif %}
    {% endfor %}
    {# <li class="page-item active">
      <a class="page-link" href="#" aria-current="page">2</a>
    </li>
    <li class="page-item">
      <a class="page-link" href="#">3</a> #}
    </li>
    {% if next is defined %}
          <li class="page-item">
            <a href="{{ path(route, query|merge({(pageParameterName):next })) }}" class="page-link">Suivant</a>
          </li>
    {% endif %}
    </ul>
  </nav>
{% endif %}