{% extends 'base.html.twig' %}

{% block title %}Register{% endblock %}

{% block body %}
<div class="container containerForm loginform">

    {{ form_errors(registrationForm) }}

    {{ form_start(registrationForm) }}
        <h1>Je m'inscris:</h1>
        {{ form_widget(registrationForm.firstName, {'attr': {'class': 'form-control form mt-3', 'placeholder':'Prénom'  }}) }}
        {{ form_widget(registrationForm.lastName, {'attr': {'class': 'form-control form mt-3', 'placeholder':'Nom'}}) }}
        {{ form_widget(registrationForm.email, {'attr': {'class': 'form-control form mt-3', 'placeholder':'Addresse e-mail'}}) }}
        {{ form_widget(registrationForm.plainPassword, {
            label: 'Password', 'attr': {'class': 'form-control form mt-3', 'placeholder':'Mot de passe'}
        }) }}
        {{ form_row(registrationForm.agreeTerms, {'label': 'J\'accepte les conditions d\'utilisation '}) }}

        <button type="submit" class="btn btn-lg btn-primary mt-4">S'inscrire</button>
    {{ form_end(registrationForm) }}
</div>
{% endblock %}
