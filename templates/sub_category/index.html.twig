{% extends 'base.html.twig' %}

{% block title %}SubCategory index{% endblock %}

{% block body %}
    <div class="container">
        <h1>SubCategory index</h1>

        <table class="table">
            <thead>
                <tr>
                    <th>Nom</th>
                    <th>Categories</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
            {% for sub_category in sub_categories %}
                <tr>
                    <td>{{ sub_category.name }}</td>
                    <td>{{ sub_category.category.name }}</td>
                    <td>
                        <a href="{{ path('app_sub_category_show', {'id': sub_category.id}) }}" class="btn btn-primary">Afficher</a>
                        <a href="{{ path('app_sub_category_edit', {'id': sub_category.id}) }}" class="btn btn-warning">Modifier</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="3">Aucune entrée</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

        <a href="{{ path('app_sub_category_new') }}" class="btn btn-success">Nouvelle sous-catégorie</a>
    </div>
{% endblock %}
