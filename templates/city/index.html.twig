{% extends 'base.html.twig' %}

{% block title %}City index{% endblock %}

{% block body %}
<div class="container">
    <h1>City index</h1>

    <table class="table ">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nom</th>
                <th>Frais de livraison</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for city in cities %}
            <tr>
                <td>{{ city.id }}</td>
                <td>{{ city.name }}</td>
                <td>{{ city.shippingCost }}</td>
                <td>
                    <a class='btn btn-primary' href="{{ path('app_city_show', {'id': city.id}) }}">Afficher</a>
                    <a class='btn btn-warning' href="{{ path('app_city_edit', {'id': city.id}) }}">Modifié</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4">Aucune entrée</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a class='btn btn-secondary' href="{{ path('app_city_new') }}">Ajouter une ville</a>
    </div>
{% endblock %}
